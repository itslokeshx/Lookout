{
  "name": "lookout",
  "version": "1.0.0",
  "private": true,
  "description": "An AI agent for your database. It investigates. It drafts. You decide what ships.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,magenta\" \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": ".venv/bin/uvicorn backend.server:app --reload --port 8000 || uvicorn backend.server:app --reload --port 8000",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
